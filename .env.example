# SynapZ-Social Environment Variables
# cp .env.example .env  →  fill in values  →  never commit .env

# API
NODE_ENV=development
API_PORT=4001
CORS_ORIGIN=http://localhost:5174

# JWT (same secret as SynapZ-Core for cross-platform token validation)
JWT_SECRET=changeme_match_synapz_core_secret

# SynapZ-Core integration (repo: synapz)
SYNAPZ_CORE_URL=http://localhost:4000
SYNAPZ_CORE_API_KEY=

# ICP Network
ICP_NETWORK=local                        # local | ic
ICP_HOST=http://127.0.0.1:4943

# ICP Canister IDs (populated after dfx deploy)
CANISTER_ID_SOCIAL_GRAPH=PENDING
CANISTER_ID_CONTENT_FEED=PENDING
CANISTER_ID_CREATOR_ECONOMY=PENDING
CANISTER_ID_MODERATION=PENDING
CANISTER_ID_MEDIA_REGISTRY=PENDING

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=sovereign
GRAFANA_PORT=3003

# Web
WEB_PORT=3002
